
#
# Model Configuration
#
CONFIG_INFERENCE_MODEL="mistralai/Mistral-7B-Instruct-v0.3"
CONFIG_INFERENCE_MODEL_REVISION="main"
CONFIG_EMBEDDING_MODEL="nomic-ai/nomic-embed-text-v1"
CONFIG_MODEL_CACHE_DIR="/workspace/.cache/huggingface"
CONFIG_TRUST_REMOTE_CODE=y
CONFIG_NOMIC_PREFIX_AUTO=y
# CONFIG_NOMIC_PREFIX_ALWAYS_QUERY is not set
# CONFIG_NOMIC_PREFIX_ALWAYS_DOCUMENT is not set
# CONFIG_NOMIC_PREFIX_NONE is not set
# end of Model Configuration

#
# Inference Backend Configuration
#
# CONFIG_BACKEND_SGLANG is not set
CONFIG_BACKEND_VLLM=y

#
# Common server settings
#
CONFIG_SERVER_HOST="0.0.0.0"
CONFIG_SERVER_PORT=30000
CONFIG_SERVER_TP_SIZE=1
CONFIG_SERVER_DTYPE="float16"
CONFIG_SERVER_CONTEXT_LENGTH=32768
CONFIG_SERVER_HEALTH_TIMEOUT=300
CONFIG_SERVER_HEALTH_INTERVAL=5
CONFIG_SERVER_HEALTH_ENDPOINT="/health"

#
# vLLM-specific settings
#
CONFIG_VLLM_GPU_MEMORY_UTILIZATION="0.85"
CONFIG_VLLM_EXTRA_ARGS="--enforce-eager --attention-backend FLASHINFER"
# end of Inference Backend Configuration

#
# Retrieval / DAG Configuration
#
CONFIG_USE_DAG=y
CONFIG_DAG_MAX_RETRIES=10
CONFIG_DAG_PROMPT_STANDARD=y
# CONFIG_DAG_PROMPT_MIN_DEPTH_BASELINE is not set
CONFIG_PLAN_PROMPT=""
CONFIG_FEWSHOT_STANDARD_ALL3=y
# CONFIG_FEWSHOT_PARALLEL_HYBRID_EXTENDED is not set
CONFIG_FINAL_REASONING_PROMPT="prompt/final_reasoning_DAG.md"
CONFIG_NOPLAN_REASONING_PROMPT="prompt/noplan_reasoning.md"
CONFIG_ROW_PROMPT="prompt/get_row_template.md"
CONFIG_COL_PROMPT="prompt/get_col_template.md"
CONFIG_SCHEMA_LINKING_PROMPT="prompt/prompt_schema_linking.md"
CONFIG_NUM_SAMPLE_ROWS=5
# end of Retrieval / DAG Configuration

#
# Output / Logging Configuration
#
CONFIG_PERSISTENT_ROOT="/workspace/AixelAsk/nlp_project"
CONFIG_EPHEMERAL_TMPDIR="/tmp"
CONFIG_RESULT_FILE="output/results.jsonl"
CONFIG_EMBEDDING_CACHE="cache/table_embeddings.jsonl"
CONFIG_LOG_FILE="output/run.log"
# CONFIG_LOG_LEVEL_DEBUG is not set
CONFIG_LOG_LEVEL_INFO=y
# CONFIG_LOG_LEVEL_WARNING is not set
# CONFIG_LOG_LEVEL_ERROR is not set
CONFIG_LOG_LLM_PROMPTS=y
CONFIG_LOG_LLM_RESPONSES=y
CONFIG_LOG_LLM_CALLS_MAX_CHARS=200000
# CONFIG_LOG_LLM_CALLS_PER_ITEM is not set
CONFIG_LLM_CALLS_SIDEFILE=""
# end of Output / Logging Configuration

#
# Runtime Configuration
#
CONFIG_MAX_WORKERS=8
CONFIG_LLM_MAX_OUTPUT_TOKENS=2048
CONFIG_LLM_RETRIES=30

#
# LLM Sampling Parameters
#
CONFIG_LLM_TEMPERATURE="0.1"
CONFIG_LLM_TOP_P="1.0"
CONFIG_LLM_TOP_K=0
CONFIG_LLM_FREQUENCY_PENALTY="0.0"
CONFIG_LLM_PRESENCE_PENALTY="0.0"
CONFIG_LLM_SEED=100

#
# Embedding Parameters
#
CONFIG_EMBEDDING_BATCH_SIZE=32
CONFIG_EMBEDDING_DEVICE="cuda:1"
CONFIG_EMBEDDING_RETRIES=5

#
# Execution Parameters
#
CONFIG_SKIP_EXISTING=y
CONFIG_CUDA_VISIBLE_DEVICES="0"

#
# Concurrency Limits
#
CONFIG_DAG_NODE_MAX_INFLIGHT=16
CONFIG_RETRIEVAL_PARALLELISM=8
CONFIG_RETRIEVAL_EMBED_BATCH_SIZE=32
CONFIG_REASONING_PARALLELISM=8
CONFIG_CLIENT_CONCURRENCY=4
CONFIG_GLOBAL_EMBEDDING_CONCURRENCY=8
# end of Runtime Configuration

#
# DAG Statistics
#
CONFIG_DAG_STATS_ENABLE=y
CONFIG_DAG_STATS_FILE="output/dag_stats.json"
CONFIG_DAG_STATS_INCLUDE_FAILED=y
# CONFIG_DAG_STATS_WRITE_PER_ITEM is not set
CONFIG_LOG_EXECUTOR_STATS=y
CONFIG_DAG_STATS_VALIDITY_ERRORS=y
# end of DAG Statistics

#
# Training Configuration
#
# CONFIG_ENABLE_TRAINING is not set
CONFIG_TRAINING_MODE_DISABLED=y
# CONFIG_TRAINING_MODE_GRPO is not set
# CONFIG_TRAINING_MODE_OVERFIT_POC is not set

#
# Overfit PoC selection
#
CONFIG_OVERFIT_POC_NUM_EXAMPLES=16
CONFIG_OVERFIT_POC_FIRST_N=y
# CONFIG_OVERFIT_POC_RANDOM_SEEDED is not set
# CONFIG_OVERFIT_POC_FIXED_INDICES_FILE is not set

#
# Training reproducibility / seeds
#
CONFIG_GLOBAL_SEED=42
CONFIG_TRAINING_SEED=-1
CONFIG_DATALOADER_SEED=-1
CONFIG_GENERATION_SEED=-1
CONFIG_REWARD_SEED=-1
CONFIG_EVAL_SEED=-1
CONFIG_SAVE_RESOLVED_SEEDS=y

#
# GRPO hyperparameters
#
CONFIG_GRPO_ENABLE=y
CONFIG_GRPO_NUM_EPOCHS=1
CONFIG_GRPO_MAX_STEPS=0
CONFIG_GRPO_BATCH_SIZE_PROMPTS=4
CONFIG_GRPO_GROUP_SIZE=8
CONFIG_GRPO_MAX_NEW_TOKENS=1024
CONFIG_GRPO_TEMPERATURE="0.7"
CONFIG_GRPO_TOP_P="0.95"
CONFIG_GRPO_TOP_K=0
CONFIG_GRPO_CLIP_EPS="0.2"
CONFIG_GRPO_KL_COEF="0.05"
CONFIG_GRPO_LR="5e-5"
CONFIG_GRPO_GRAD_ACCUM=2
CONFIG_GRPO_SAVE_EVERY_STEPS=50
CONFIG_GRPO_EVAL_EVERY_STEPS=25

#
# Reward configuration
#
CONFIG_REWARD_WEIGHTED_SUM=y
CONFIG_REWARD_WEIGHT_CORRECTNESS="1.0"
CONFIG_REWARD_WEIGHT_VALIDITY="0.5"
CONFIG_REWARD_WEIGHT_DEPTH="0.1"
CONFIG_REWARD_WEIGHT_INVALID_PENALTY="0.5"
# CONFIG_REWARD_DEPTH_NONE is not set
CONFIG_REWARD_DEPTH_DIVIDE_BY_MAX=y
# CONFIG_REWARD_DEPTH_CLAMPED_LINEAR is not set
CONFIG_REWARD_MAX_DEPTH=10
CONFIG_REWARD_INVALID_IF_PARSE_FAILS=y
# CONFIG_REWARD_CORRECTNESS_PARTIAL_CREDIT is not set

#
# LoRA / QLoRA configuration
#
# CONFIG_TRAIN_USE_4BIT is not set
CONFIG_TRAIN_BNB_4BIT_QUANT_TYPE="nf4"
CONFIG_TRAIN_BNB_4BIT_COMPUTE_DTYPE="bfloat16"
CONFIG_TRAIN_USE_GRADIENT_CHECKPOINTING=y
CONFIG_TRAIN_LORA_R=16
CONFIG_TRAIN_LORA_ALPHA=32
CONFIG_TRAIN_LORA_DROPOUT="0.05"
CONFIG_TRAIN_LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
CONFIG_TRAIN_LORA_BIAS="none"
# CONFIG_TRAIN_LOAD_FROM_CHECKPOINT is not set

#
# Checkpoint / model export
#
CONFIG_TRAIN_OUTPUT_DIR="output/train"
CONFIG_TRAIN_SAVE_LATEST=y
CONFIG_TRAIN_SAVE_BEST_BY="eval_reward_mean"
# CONFIG_TRAIN_SAVE_MERGED_ADAPTER is not set
CONFIG_TRAIN_SAVE_ADAPTER_ONLY=y
# end of Training Configuration

#
# Training Statistics & Curves
#
CONFIG_TRAIN_STATS_ENABLE=y
CONFIG_TRAIN_STATS_FILE=""
CONFIG_TRAIN_STATS_PER_STEP_JSONL=""
CONFIG_TRAIN_STATS_PER_EVAL_JSONL=""
CONFIG_TRAIN_CURVES_DIR=""
CONFIG_TRAIN_CURVES_TEX_ENABLE=y
CONFIG_TRAIN_CURVES_COMPILE_ENABLE=y
CONFIG_TRAIN_CURVES_UPDATE_EVERY_STEPS=25
CONFIG_TRAIN_CURVES_COMPILE_EVERY_STEPS=100
CONFIG_TRAIN_CURVES_COMPILE_AT_END=y
CONFIG_TRAIN_CURVES_LATEXMK=y
CONFIG_TRAIN_CURVES_LATEX_ENGINE="pdflatex"
CONFIG_TRAIN_CURVES_PDFLATEX_TIMEOUT_SEC=60
CONFIG_TRAIN_CURVES_KEEP_LAST_N_POINTS=0
CONFIG_TRAIN_STATS_FLUSH_EVERY_STEPS=10
# end of Training Statistics & Curves

#
# Post-Training Test Evaluation
#

#
# Checkpoint selection
#
CONFIG_TEST_TRAINED_CHECKPOINT_BEST=y
# CONFIG_TEST_TRAINED_CHECKPOINT_LATEST is not set
# CONFIG_TEST_TRAINED_CHECKPOINT_MERGED is not set
# CONFIG_TEST_TRAINED_CHECKPOINT_EXPLICIT_PATH is not set

#
# Output paths
#
CONFIG_TEST_TRAINED_OUTPUT_DIR=""
CONFIG_TEST_TRAINED_RESULT_FILE=""
CONFIG_TEST_TRAINED_DAG_STATS_FILE=""
# end of Post-Training Test Evaluation
