menu "Inference Backend Configuration"

choice
	prompt "Inference backend"
	default BACKEND_SGLANG

config BACKEND_SGLANG
	bool "SGLang"
	help
	  Use SGLang as the inference server (OpenAI-compatible API).

config BACKEND_VLLM
	bool "vLLM"
	help
	  Use vLLM as the inference server (OpenAI-compatible API).

endchoice

comment "Common server settings"

config SERVER_HOST
	string "Server bind host"
	default "0.0.0.0"
	help
	  --host argument for the inference server.

config SERVER_PORT
	int "Server port"
	default 30000
	help
	  --port argument for the inference server.

config SERVER_TP_SIZE
	int "Tensor parallelism size"
	default 1
	help
	  Number of GPUs for tensor-parallel inference.

config SERVER_DTYPE
	string "Model dtype"
	default "float16"
	help
	  Model dtype (e.g. float16, bfloat16, auto).

config SERVER_CONTEXT_LENGTH
	int "Context length"
	default 8192
	help
	  Maximum context length. Mistral-7B-v0.3 supports up to 32768.

config SERVER_HEALTH_TIMEOUT
	int "Health check timeout (seconds)"
	default 300
	help
	  Seconds to wait for the server health probe to return 200.

config SERVER_HEALTH_INTERVAL
	int "Health check poll interval (seconds)"
	default 5
	help
	  Seconds between health check polls.

config SERVER_HEALTH_ENDPOINT
	string "Health check endpoint"
	default "/health"
	help
	  Primary health-check endpoint path.

comment "SGLang-specific settings"
	depends on BACKEND_SGLANG

config SGLANG_MEM_FRACTION
	string "KV-cache memory fraction (SGLang)"
	default "0.85"
	depends on BACKEND_SGLANG
	help
	  --mem-fraction-static for SGLang. Fraction of GPU memory allocated
	  to the KV cache.

config SGLANG_EXTRA_ARGS
	string "Extra SGLang arguments"
	default ""
	depends on BACKEND_SGLANG
	help
	  Appended verbatim to the SGLang launch command.

comment "vLLM-specific settings"
	depends on BACKEND_VLLM

config VLLM_GPU_MEMORY_UTILIZATION
	string "GPU memory utilization (vLLM)"
	default "0.85"
	depends on BACKEND_VLLM
	help
	  --gpu-memory-utilization for vLLM. Fraction of GPU memory for
	  KV cache and model weights.

config VLLM_EXTRA_ARGS
	string "Extra vLLM arguments"
	default ""
	depends on BACKEND_VLLM
	help
	  Appended verbatim to the vLLM launch command.

endmenu
