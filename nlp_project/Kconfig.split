menu "Split Configuration"

comment "Controls how train, validation, and test splits are constructed"

choice SPLIT_MODE
	prompt "Split construction mode"
	default SPLIT_MODE_SEEDED_RATIO
	help
	  How train/validation/test splits are constructed.

config SPLIT_MODE_SEEDED_RATIO
	bool "Seeded ratio — split a single file by ratio + seed"
	help
	  Training loads TRAIN_DATASET_PATH and optionally splits into
	  train/dev using TRAIN_SPLIT_RATIO with TRAIN_SPLIT_SEED.
	  Inference loads INFERENCE_DATASET_PATH. Supports only single-file
	  datasets (WikiTQ-4k, WikiTQ+, or custom).

config SPLIT_MODE_EXPLICIT_INDICES
	bool "Explicit indices — per-dataset index lists"
	help
	  Build train/validation/test splits from per-dataset index lists.
	  Each split is the union of examples across supported datasets.

config SPLIT_MODE_OVERFIT_POC
	bool "Overfit PoC — tiny subset for proof of concept"
	help
	  Uses CONFIG_OVERFIT_POC_* symbols. Accepted only by train_main.py
	  when TRAINING_MODE=TRAINING_MODE_OVERFIT_POC. Rejected at startup
	  by src/main.py and test_main.py.

endchoice

comment "Per-dataset explicit index lists (used with SPLIT_MODE_EXPLICIT_INDICES)"

config SPLIT_TRAIN_WIKITQ_4K_INDICES
	string "WikiTQ-4k train indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ-4k/train.jsonl
	  for the train split.

config SPLIT_TRAIN_WIKITQ_PLUS_INDICES
	string "WikiTQ+ train indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ+/train.jsonl
	  for the train split.

config SPLIT_TRAIN_SCALABILITY_INDICES
	string "Scalability train indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into the Scalability combined
	  dataset for the train split.

config SPLIT_VALID_WIKITQ_4K_INDICES
	string "WikiTQ-4k validation indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ-4k/valid.jsonl
	  for the validation split.

config SPLIT_VALID_WIKITQ_PLUS_INDICES
	string "WikiTQ+ validation indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ+/valid.jsonl
	  for the validation split.

config SPLIT_VALID_SCALABILITY_INDICES
	string "Scalability validation indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into the Scalability combined
	  dataset for the validation split.

config SPLIT_TEST_WIKITQ_4K_INDICES
	string "WikiTQ-4k test indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ-4k/test.jsonl
	  for the test split.

config SPLIT_TEST_WIKITQ_PLUS_INDICES
	string "WikiTQ+ test indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into dataset/WikiTQ+/test.jsonl
	  for the test split.

config SPLIT_TEST_SCALABILITY_INDICES
	string "Scalability test indices"
	default ""
	depends on SPLIT_MODE_EXPLICIT_INDICES
	help
	  Comma-separated zero-based indices into the Scalability combined
	  dataset for the test split.

endmenu
